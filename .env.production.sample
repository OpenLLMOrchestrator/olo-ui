# Production environment — copy to .env.production and set in your deployment (e.g. Kubernetes, ECS, or docker-compose).
# Used when running the combined image or olo-be in production.

# ---- Backend (olo-be) ----
SERVER_PORT=8082
# Redis (recommended in production for persistent tenant list)
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
OLO_TENANT_IDS=olo:tenants

# ---- Optional: disable Redis (in-memory store; data lost on restart) ----
# SPRING_AUTOCONFIGURE_EXCLUDE=org.springframework.boot.autoconfigure.data.redis.RedisAutoConfiguration

# ---- Security / tuning (examples) ----
# SERVER_TOMCAT_MAX_THREADS=200
# SPRING_DATA_REDIS_PASSWORD=your-redis-password
