# Demo environment — copy to .env.demo for a demo or staging stack.
# Single-node demo: combined app + Redis; good for try-it-out or internal demos.

# ---- Backend (olo-be) ----
SERVER_PORT=8082
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
OLO_TENANT_IDS=olo:tenants

# ---- Optional: same as production but with demo-specific key ----
# OLO_TENANT_IDS=olo:demo:tenants
