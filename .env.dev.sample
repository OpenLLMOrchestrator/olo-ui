# Development environment — copy to .env.dev and adjust.
# Run backend with: cd olo-be && ./gradlew bootRun
# Run frontend with: cd olo-ui && npm run dev (proxies /api to backend; see vite.config.ts).

# ---- Backend (olo-be) ----
SERVER_PORT=8082
# Redis (optional in dev; omit or disable to use in-memory tenant store).
# When running in Docker / olo-docker network, use hostname "redis" so backend reaches Redis.
SPRING_DATA_REDIS_HOST=redis
SPRING_DATA_REDIS_PORT=6379
# Tenant list Redis key (only used when Redis is enabled)
OLO_TENANT_IDS=olo:tenants

# ---- Frontend (olo-ui) ----
# Vite dev server runs on port 3000 and proxies /api to backend (see vite.config.ts).
# Proxy target: http://localhost:8082 for local olo-be, or http://localhost:7080 when using main OLO API (olo-docker).
# When UI runs inside olo-docker stack, API is at http://olo:7080 (internal); browser uses http://localhost:7080.
# No env needed for dev; API base is /api/v1.
